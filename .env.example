# Local model paths and API configuration
YOLO_MODEL=yolov8x.pt
HORIZONNET_WEIGHTS=./api_endpoint/model.pth
# HORIZONNET_API_KEY is loaded from env but not currently used by the pipeline
HORIZONNET_API_KEY=your_horizonnet_key_here

# Required for Roboflow door/window detection
ROBOFLOW_API_KEY=your_roboflow_key_here
ROBOFLOW_URL=https://detect.roboflow.com/door-window-detection-pipvh/1

OUTPUT_DIR=./api_endpoint/outputs
ROOM_SCALE=5.0
WALL_THICKNESS=0.18
DOOR_WIDTH_M=0.90
WINDOW_WIDTH_M=1.20
DXF_SCALE=100